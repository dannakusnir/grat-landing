---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Approach from '../components/Approach.astro';
import Process from '../components/Process.astro';
import Stats from '../components/Stats.astro';
import Portfolio from '../components/Portfolio.astro';
import CtaBand from '../components/CtaBand.astro';
import Neighborhoods from '../components/Neighborhoods.astro';
import WhoIsFor from '../components/WhoIsFor.astro';
import Trust from '../components/Trust.astro';
import SocialProof from '../components/SocialProof.astro';
import Faq from '../components/Faq.astro';
import CtaForm from '../components/CtaForm.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="GRAT Holdings | השקעות נדל״ן מובנות בשיקגו"
  description="GRAT Holdings בונה מסלולי השקעה מובנים בנדל״ן למגורים בשיקגו. החל מ-$50K. קבעו שיחת היכרות."
  lang="he"
  dir="rtl"
>
  <Header lang="he" ctaText="לקביעת שיחה" altLangUrl="/" altLangLabel="EN" />
  <main>
    <Hero lang="he" />
    <Problem lang="he" />
    <Approach lang="he" />
    <Process lang="he" />
    <Stats lang="he" />
    <Portfolio lang="he" />
    <CtaBand lang="he" variant="dark" />
    <Neighborhoods lang="he" />
    <WhoIsFor lang="he" />
    <Trust lang="he" />
    <SocialProof lang="he" />
    <CtaBand lang="he" variant="light" />
    <Faq lang="he" />
    <CtaForm lang="he" />
  </main>
  <Footer lang="he" />
</Base>

---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Approach from '../components/Approach.astro';
import Process from '../components/Process.astro';
import Stats from '../components/Stats.astro';
import Portfolio from '../components/Portfolio.astro';
import CtaBand from '../components/CtaBand.astro';
import Neighborhoods from '../components/Neighborhoods.astro';
import WhoIsFor from '../components/WhoIsFor.astro';
import Trust from '../components/Trust.astro';
import SocialProof from '../components/SocialProof.astro';
import Faq from '../components/Faq.astro';
import CtaForm from '../components/CtaForm.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="GRAT Holdings | Structured Real Estate Investment in Chicago"
  description="GRAT Holdings builds structured investment paths into Chicago residential real estate for Israeli investors. Starting at $50K. Book an intro call."
>
  <Header lang="en" ctaText="Book a Call" altLangUrl="/he" altLangLabel="עב" />
  <main>
    <Hero lang="en" />
    <Problem lang="en" />
    <Approach lang="en" />
    <Process lang="en" />
    <Stats lang="en" />
    <Portfolio lang="en" />
    <CtaBand lang="en" variant="dark" />
    <Neighborhoods lang="en" />
    <WhoIsFor lang="en" />
    <Trust lang="en" />
    <SocialProof lang="en" />
    <CtaBand lang="en" variant="light" />
    <Faq lang="en" />
    <CtaForm lang="en" />
  </main>
  <Footer lang="en" />
</Base>

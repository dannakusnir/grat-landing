---
interface Props {
  lang?: string;
  variant?: 'dark' | 'light';
}

const { lang = 'en', variant = 'dark' } = Astro.props;

const content = {
  en: {
    text: 'Ready to explore your first investment?',
    cta: 'Book an Intro Call',
  },
  he: {
    text: 'מוכן לבדוק את ההשקעה הראשונה שלך?',
    cta: 'לקביעת שיחה',
  },
};

const t = content[lang as keyof typeof content];
const isDark = variant === 'dark';
---

<div class={`py-12 md:py-16 ${isDark ? 'bg-navy border-y border-gold/10' : 'bg-[#e8e4db] border-y border-navy/5'}`}>
  <div class="max-w-[800px] mx-auto px-5 md:px-8 flex flex-col md:flex-row items-center justify-between gap-5">
    <p class={`text-xl md:text-2xl font-bold text-center md:text-left ${isDark ? 'text-offwhite' : 'text-navy'}`}>
      {t.text}
    </p>
    <a
      href="#cta"
      class="flex-shrink-0 bg-gold text-navy font-bold text-base md:text-lg px-8 py-3.5 rounded-lg hover:bg-gold-warm transition-all hover:shadow-lg hover:shadow-gold/20 whitespace-nowrap"
    >
      {t.cta}
    </a>
  </div>
</div>

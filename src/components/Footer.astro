---
interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;

const content = {
  en: {
    contact: 'Contact',
    privacy: 'Privacy Policy',
    terms: 'Terms of Service',
    privacyText: 'GRAT Holdings LLC is committed to protecting your personal information. We do not sell, share or distribute your data to third parties. All information submitted through this website is kept strictly confidential and used only for the purpose of evaluating investment opportunities.',
    rights: 'All rights reserved.',
  },
  he: {
    contact: 'צור קשר',
    privacy: 'מדיניות פרטיות',
    terms: 'תנאי שימוש',
    privacyText: 'GRAT Holdings LLC מחויבת להגנה על המידע האישי שלך. אנחנו לא מוכרים, משתפים או מפיצים את הנתונים שלך לצדדים שלישיים. כל מידע שנשלח דרך אתר זה נשמר בסודיות מוחלטת ומשמש אך ורק לצורך בחינת הזדמנויות השקעה.',
    rights: 'כל הזכויות שמורות.',
  },
};

const t = content[lang as keyof typeof content];
---

<footer class="bg-[#F0EDE5] text-navy pt-16 pb-8">
  <div class="max-w-[1200px] mx-auto px-5 md:px-8">
    <!-- Main footer content -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 mb-12">
      <!-- Logo & company -->
      <div class="flex flex-col items-center md:items-start">
        <img src="/images/logo.png" alt="GRAT Holdings" class="h-20 md:h-24 w-auto mb-4" />
        <p class="text-navy/50 text-base">GRAT Holdings LLC</p>
        <p class="text-navy/40 text-sm mt-1">Chicago, Illinois</p>
      </div>

      <!-- Contact -->
      <div class="text-center md:text-left">
        <h4 class="text-gold text-sm uppercase tracking-wider font-semibold mb-4">{t.contact}</h4>
        <div class="space-y-2">
          <a href="mailto:info@GRATgroup.com" class="block text-navy/70 text-base hover:text-gold transition-colors">
            info@GRATgroup.com
          </a>
          <a href="tel:+13125550123" class="block text-navy/70 text-base hover:text-gold transition-colors">
            (312) 555-0123
          </a>
          <p class="text-navy/40 text-sm mt-2">Chicago, Illinois</p>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="text-center md:text-left">
        <h4 class="text-gold text-sm uppercase tracking-wider font-semibold mb-4">
          {lang === 'he' ? 'קישורים' : 'Quick Links'}
        </h4>
        <div class="space-y-2">
          <a href="#cta" class="block text-navy/60 text-base hover:text-gold transition-colors">
            {lang === 'he' ? 'קביעת שיחה' : 'Book a Call'}
          </a>
          <a href="#privacy-section" class="block text-navy/60 text-base hover:text-gold transition-colors">
            {t.privacy}
          </a>
        </div>
      </div>
    </div>

    <!-- Privacy statement -->
    <div id="privacy-section" class="border-t border-navy/10 pt-8 mb-8">
      <h4 class="text-sm text-navy/50 uppercase tracking-wider font-semibold mb-3">{t.privacy}</h4>
      <p class="text-navy/40 text-sm leading-relaxed max-w-3xl">
        {t.privacyText}
      </p>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-navy/8 pt-6 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-navy/30 text-xs">
        &copy; 2026 GRAT Holdings LLC. {t.rights}
      </p>
      <div class="flex gap-4 text-xs">
        <a href="#privacy-section" class="text-navy/30 hover:text-gold transition-colors">{t.privacy}</a>
        <a href="#" class="text-navy/30 hover:text-gold transition-colors">{t.terms}</a>
      </div>
    </div>
  </div>
</footer>

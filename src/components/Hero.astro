---
interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;

const content = {
  en: {
    eyebrow: 'STRUCTURED REAL ESTATE INVESTMENT',
    h1_1: 'Your entry point into',
    h1_2: 'U.S. real estate.',
    sub: 'GRAT Holdings creates clear investment paths into Chicago residential real estate. Starting at $50K.',
    cta: "Let's Talk About Your First Investment",
    micro: 'A short intro call, no commitment.',
  },
  he: {
    eyebrow: 'נדל"ן אמריקאי. גישה ישראלית.',
    h1_1: 'הכסף שלך.',
    h1_2: 'המבנה שלנו.',
    sub: 'GRAT Holdings מנהלת השקעות נדל"ן בשיקגו, מרכישה ועד מכירה. החל מ-$50K.',
    cta: 'רוצה להבין אם זה מתאים לך?',
    micro: 'שיחה קצרה, אפס מחויבות.',
  },
};

const t = content[lang as keyof typeof content];
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden section-wave" style="background: #0B1D3A;">
  <!-- Background -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-navy-dark ken-burns">
      <img
        src="/images/hero-bg.jpg"
        alt=""
        class="w-full h-full object-cover opacity-50"
        loading="eager"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-[#2a4a7a]/60 via-[#1e3d6b]/55 to-navy"></div>
  </div>

  <!-- Floating particles -->
  <div id="hero-particles" class="absolute inset-0 pointer-events-none overflow-hidden"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-[1200px] mx-auto px-5 md:px-8 text-center pt-20 pb-16">
    <p class="eyebrow-reveal text-gold text-base md:text-xl tracking-[0.2em] uppercase font-semibold mb-6 md:mb-8">
      {t.eyebrow}
    </p>

    <h1 class="text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-extrabold leading-[1.08] mb-6 md:mb-8 fade-in" style="transition-delay: 200ms">
      <span id="hero-typed" class="block"></span>
      <span class="block gold-shimmer">{t.h1_2}</span>
    </h1>
    <!-- Hidden text for typewriter -->
    <span id="hero-typed-source" class="hidden">{t.h1_1}</span>

    <p class="text-gray-light text-lg md:text-xl lg:text-2xl max-w-2xl mx-auto mb-8 md:mb-10 leading-relaxed fade-in" style="transition-delay: 400ms">
      {t.sub}
    </p>

    <a
      href="#cta"
      class="magnetic-btn inline-block bg-gold text-navy font-bold text-base md:text-lg px-8 py-4 md:px-10 md:py-4 rounded hover:bg-gold-warm transition-all w-full md:w-auto cta-pulse fade-in hover:scale-105"
      style="transition-delay: 600ms"
    >
      {t.cta}
    </a>

    <p class="text-gray-light/60 text-sm mt-4 fade-in" style="transition-delay: 700ms">
      {t.micro}
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 scroll-indicator">
    <svg class="w-6 h-10 text-gold/50" viewBox="0 0 24 40" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="1" y="1" width="22" height="38" rx="11" />
      <circle cx="12" cy="12" r="3" fill="currentColor">
        <animate attributeName="cy" values="10;18;10" dur="2s" repeatCount="indefinite" />
      </circle>
    </svg>
  </div>
</section>

<script>
  // Floating particles
  const container = document.getElementById('hero-particles');
  if (container) {
    for (let i = 0; i < 10; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      p.style.left = Math.random() * 100 + '%';
      p.style.bottom = Math.random() * 50 + '%';
      p.style.animationDuration = (4 + Math.random() * 8) + 's';
      p.style.animationDelay = (Math.random() * 6) + 's';
      p.style.width = (2 + Math.random() * 4) + 'px';
      p.style.height = p.style.width;
      p.style.opacity = '0';
      container.appendChild(p);
    }
  }

  // Typewriter effect
  const typedEl = document.getElementById('hero-typed');
  const sourceEl = document.getElementById('hero-typed-source');
  if (typedEl && sourceEl) {
    const text = sourceEl.textContent || '';
    let i = 0;
    typedEl.classList.add('typewriter-cursor');

    function type() {
      if (i <= text.length) {
        typedEl!.textContent = text.slice(0, i);
        i++;
        setTimeout(type, 60 + Math.random() * 40);
      } else {
        // Remove cursor after done
        setTimeout(() => typedEl!.classList.remove('typewriter-cursor'), 1500);
      }
    }

    // Start typing after a short delay
    setTimeout(type, 800);
  }
</script>
